local Players = game:GetService("Players")
local obbyFolder = workspace:WaitForChild("Obby")
local COMPLETED_COLOR = Color3.fromRGB(0, 255, 0)
local DEFAULT_COLOR = Color3.fromRGB(255, 0, 0)
local playerProgress = {}

local function getObbyParts()
	local parts = {}
	for _, child in ipairs(obbyFolder:GetChildren()) do
		if child:IsA("BasePart") and child.Name:match("^ObbyPart%d+$") then
			table.insert(parts, child)
		end
	end
	return parts
end

local function resetPartsForPlayer(player)
	local completedByPlayer = playerProgress[player.UserId] or {}
	playerProgress[player.UserId] = {}
	for partName, _ in pairs(completedByPlayer) do
		local part = obbyFolder:FindFirstChild(partName)
		if not part then continue end
		local otherPlayerHasIt = false
		for userId, progress in pairs(playerProgress) do
			if userId ~= player.UserId and progress[partName] then
				otherPlayerHasIt = true
				break
			end
		end
		if not otherPlayerHasIt then
			part.Color = DEFAULT_COLOR
		end
	end
end

local function setupObbyPart(part)
	part.Color = DEFAULT_COLOR
	part.Touched:Connect(function(hit)
		local character = hit.Parent
		local player = Players:GetPlayerFromCharacter(character)
		if not player then return end
		if not playerProgress[player.UserId] then
			playerProgress[player.UserId] = {}
		end
		if not playerProgress[player.UserId][part.Name] then
			playerProgress[player.UserId][part.Name] = true
			part.Color = COMPLETED_COLOR
		end
	end)
end

local function onCharacterAdded(character, player)
	local humanoid = character:WaitForChild("Humanoid")
	humanoid.Died:Connect(function()
		resetPartsForPlayer(player)
	end)
end

Players.PlayerAdded:Connect(function(player)
	playerProgress[player.UserId] = {}
	player.CharacterAdded:Connect(function(character)
		onCharacterAdded(character, player)
	end)
end)

Players.PlayerRemoving:Connect(function(player)
	resetPartsForPlayer(player)
	playerProgress[player.UserId] = nil
end)

for _, part in ipairs(getObbyParts()) do
	setupObbyPart(part)
end
